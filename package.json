{
  "name": "think-bot-sp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build --browser chrome",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:component": "vitest run tests/component --passWithNoTests",
    "test:e2e": "playwright test --config=./playwright.config.ts --pass-with-no-tests",
    "lint": "eslint .",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.38",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "@eslint/js": "10.0.1",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "jsdom": "29.0.1",
    "typescript": "6.0.2",
    "vitest": "4.1.2",
    "wxt": "0.20.20"
  }
}
