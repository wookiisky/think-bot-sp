{
  "name": "think-bot-sp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build --browser chrome",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:component": "vitest run tests/component --passWithNoTests",
    "test:e2e": "playwright test --config=./playwright.config.ts --pass-with-no-tests",
    "lint": "eslint --ignore-pattern \".wxt/**\" --ignore-pattern \".output/**\" --ignore-pattern \"playwright-report/**\" --ignore-pattern \"test-results/**\" .",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.0.306",
    "@types/node": "^22.15.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@wxt-dev/module-react": "^1.1.4",
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.3",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "vitest": "^3.1.1",
    "wxt": "^0.20.6"
  }
}
